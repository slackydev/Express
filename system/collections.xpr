{$rangechecks on}
(*
  This functions as an experimental test for generics and real world usage.
*)

// -- 1. TList<T> Implementation ------------------------------------------------
type TList<T> = class
  var FItems: array of T
  var FCount: Int32
  var FCapacity: Int32

  // Constructor
  constructor Create()
    self.FCount := 0
    self.FCapacity := 0
    self.FItems.SetLen(0)

  // -- Capacity & Count Management --
  func GetCount(): Int32
    return self.FCount

  func GetCapacity(): Int32
    return self.FCapacity

  func SetCapacity(newCapacity: Int32)
    if(newCapacity < self.FCount) then
      self.FCount := newCapacity
    self.FItems.SetLen(newCapacity)
    self.FCapacity := newCapacity

  // -- Core Methods --
  @opt('jit:max;rangechecks:off')
  func Add(item: T): Int32
    if(self.FCount < self.FCapacity)then
      self.FItems[self.FCount] := item
      self.FCount += 1
      return self.FCount - 1
    
    // fail path
    var newCap := self.FCapacity * 2
    if(newCap = 0) then newCap := 4
    self.SetCapacity(newCap)

    self.FItems[self.FCount] := item
    self.FCount += 1
    return self.FCount - 1

  @opt('jit:max;rangechecks:off')
  func Insert(index: Int32; item: T)
    if(index < 0) return
    if(index > self.FCount) then index := self.FCount
    
    // Grow if necessary
    if(self.FCount >= self.FCapacity) then
      var newCap := self.FCapacity * 2
      if(newCap = 0) then newCap := 4
      self.SetCapacity(newCap)
    
    // Shift elements to the right to make room
    for(var i := self.FCount; i > index; i -= 1) do
      self.FItems[i] := self.FItems[i - 1]
      
    self.FItems[index] := item
    self.FCount += 1

  @opt('jit:max;rangechecks:off')
  func Delete(index: Int32)
    if(index < 0) return
    if(index >= self.FCount) return
    
    // Shift elements to the left to overwrite
    for(var i := index; i < self.FCount - 1; i += 1) do
      self.FItems[i] := self.FItems[i + 1]
      
    self.FCount -= 1

  @opt('jit:max;rangechecks:off')
  func Remove(item: T): Bool
    var idx := self.IndexOf(item)
    if(idx >= 0) then
      self.Delete(idx)
      return True
    return False

  @opt('jit:max;rangechecks:off')
  func IndexOf(item: T): Int32
    for(var i := 0; i < self.FCount; i += 1) do
      if(self.FItems[i] = item) then
        return i
    return -1

  func Clear()
    self.FCount := 0

  // -- Index Access --
  func GetItem(index: Int32): T
    return self.FItems[index]

  func SetItem(index: Int32; item: T)
    if(index >= 0) then
      if(index < self.FCount) then
        self.FItems[index] := item

  // -- Utility [hashable]
  func ToStr(): string
    result := self.FItems.slice(0, self.FCount).ToStr();
  
  
  // -- Default property index access
  // allows for-loop iterations
  property __index__(index: Int32): T
    return self.FItems[index]

  property __index__(index: Int32; item: T)
    if(index >= 0) then
      if(index < self.FCount) then
        self.FItems[index] := item
        
  func High(): Int32;
    return self.FCount - 1
    
    
    
    
// -- TDictionary<K, V> Implementation -----------------------------
type TDictionary<K, V> = class
  var FKeys: array of K
  var FValues: array of V
  var FStates: array of Int8 // 0 = Empty, 1 = Occupied, 2 = Deleted (Tombstone)
  var FCount: Int32
  var FCapacity: Int32

  constructor Create()
    self.FCount := 0
    self.FCapacity := 16
    self.FKeys.SetLen(16)
    self.FValues.SetLen(16)
    self.FStates.SetLen(16)

  func Clear()
    self.FCount := 0
    for(var i := 0; i < self.FCapacity; i += 1) do
      self.FStates[i] := 0

  // Universal Hash Function (DJB2)
  // Converts any generic key to a string, then computes a 32-bit hash.
  func HashKey(key: K): Int32
    var s := key.ToStr()
    var h := 5381
    for(var i := 0; i < s.Len(); i += 1) do
      h := ((h shl 5) + h) + Int32(s[i])
    
    if (h < 0) then h := -h
    return h

  func IndexOf(key: K): Int32
    if (self.FCapacity = 0) then return -1
    
    var h := self.HashKey(key)
    var idx := h % self.FCapacity
    var startIdx := idx
    
    while (true) do
      var state := self.FStates[idx]
      if (state = 0) then
        return -1 // Hit an empty slot, key does not exist
        
      if (state = 1) then
        if (self.FKeys[idx] = key) then
          return idx // Found the key
          
      idx := (idx + 1) % self.FCapacity
      if (idx = startIdx) then
        return -1 // Dictionary is completely full (should never happen due to resizing)
        
    return -1

  func Resize(newCap: Int32)
    var oldKeys := self.FKeys
    var oldVals := self.FValues
    var oldStates := self.FStates
    var oldCap := self.FCapacity

    self.FCapacity := newCap
    self.FKeys.SetLen(newCap)
    self.FValues.SetLen(newCap)
    self.FStates.SetLen(newCap)
    
    for(var i := 0; i < newCap; i += 1) do 
      self.FStates[i] := 0
    
    self.FCount := 0
    
    // Rehash existing occupied slots into the new arrays
    for(var i := 0; i < oldCap; i += 1) do
      if (oldStates[i] = 1) then
        self.Add(oldKeys[i], oldVals[i])

  func Add(key: K; value: V)
    // Enforce a 75% load factor to maintain fast lookups
    if (self.FCount * 4 >= self.FCapacity * 3) then
      var newCap := self.FCapacity * 2
      if(newCap = 0) then newCap := 16
      self.Resize(newCap)

    var h := self.HashKey(key)
    var idx := h % self.FCapacity
    var startIdx := idx
    var insertIdx := -1

    while(True) do
      var state := self.FStates[idx]
      
      // Track the first empty or deleted slot we find for insertion
      if (state = 0) then
        if (insertIdx = -1) then insertIdx := idx
        break
        
      if (state = 2) then
        if (insertIdx = -1) then insertIdx := idx
        
      // If the key already exists, overwrite it
      if (state = 1) then
        if (self.FKeys[idx] = key) then
          insertIdx := idx
          self.FCount -= 1 // Subtract so the +1 at the end balances out
          break
          
      idx := (idx + 1) % self.FCapacity
      if (idx = startIdx) then break

    if (insertIdx >= 0) then
      self.FKeys[insertIdx] := key
      self.FValues[insertIdx] := value
      self.FStates[insertIdx] := 1
      self.FCount += 1

  func Remove(key: K): Bool
    var idx := self.IndexOf(key)
    if (idx >= 0) then
      self.FStates[idx] := 2 // Mark as tombstone (Deleted)
      self.FCount -= 1
      return True
    return False

  func ContainsKey(key: K): Bool
    return self.IndexOf(key) >= 0
    
  func TryGetValue(key: K; ref outVal: V): Bool
    var idx := self.IndexOf(key)
    if (idx >= 0) then
      outVal := self.FValues[idx]
      return True
    return False

  func GetKeys(): array of K
    Result.SetLen(self.FCount)
    var j := 0
    for(var i := 0; i < self.FCapacity; i += 1) do
      if(self.FStates[i] = 1) then
        Result[j] := self.FKeys[i]
        j += 1

  func GetValues(): array of V
    Result.SetLen(self.FCount)
    var j := 0
    for(var i := 0; i < self.FCapacity; i += 1) do
      if(self.FStates[i] = 1) then
        Result[j] := self.FValues[i]
        j += 1

  func Len(): Int => self.FCount
  func High(): Int => self.FCount - 1
  
  // -- Default Properties & Helpers ------------------------------------------
  property Keys(): array of K
    return self.GetKeys()
  
  property Values(): array of V
    return self.GetValues()

  // Default indexers for dict[key] := val
  property __index__(key: K): V
    var idx := self.IndexOf(key)
    if (idx >= 0) then
      return self.FValues[idx]

    // If not found, return a default initialized value
    var defaultVal: V
    return defaultVal

  property __index__(key: K; value: V)
    self.Add(key, value)
    
    

// -- TSet<T> Implementation ---------------------------------
type TSet<T> = class
  type TSetDict = specialize TDictionary<T, Bool>;
  var FDict: TSetDict;
  
  // -- Constructor / Destructor -----------------------------
  constructor Create()
    self.FDict := new TSetDict()

  // -- Basic Operations -------------------------------------
  func Add(item: T)
    self.FDict.Add(item, true)

  func Remove(item: T): Bool
    return self.FDict.Remove(item)

  func Contains(item: T): Bool
    return self.FDict.ContainsKey(item)

  func Clear()
    self.FDict.Clear()

  func Len(): Int32
    return self.FDict.Len()

  func High(): Int32
    return self.FDict.Len() - 1

  func IsEmpty(): Bool
    return self.Len() = 0

  // -- Conversion / Access ----------------------------------
  func ToArray(): array of T
    return self.FDict.Keys

  func ToStr(): string
    return self.ToArray().ToStr()

  // -- Set Operations ---------------------------------------

  // Union: elements in either set
  func Union(other: TSet): TSet
    result := new TSet()

    // Add all from self
    var keys := self.FDict.Keys
    for(var i := 0; i < keys.Len(); i += 1) do
      result.Add(keys[i])

    // Add all from other
    var otherKeys := other.FDict.Keys
    for(var i := 0; i < otherKeys.Len(); i += 1) do
      result.Add(otherKeys[i])

  // Intersection: elements in both sets
  func Intersect(other: TSet): TSet
    result := new TSet()

    var keys := self.FDict.Keys
    for(var i := 0; i < keys.Len(); i += 1) do
      if(other.Contains(keys[i])) then
        result.Add(keys[i])

  // Difference: elements in self but not in other
  func Difference(other: TSet): TSet
    result := new TSet()

    var keys := self.FDict.Keys
    for(var i := 0; i < keys.Len(); i += 1) do
      if(not other.Contains(keys[i])) then
        result.Add(keys[i])

  // Symmetric Difference: elements in either but not both
  func SymmetricDifference(other: TSet): TSet
    result := new TSet()

    var keys := self.FDict.Keys
    for(var i := 0; i < keys.Len(); i += 1) do
      if(not other.Contains(keys[i])) then
        result.Add(keys[i])

    var otherKeys := other.FDict.Keys
    for(var i := 0; i < otherKeys.Len(); i += 1) do
      if(not self.Contains(otherKeys[i])) then
        result.Add(otherKeys[i])

  // -- Relations --------------------------------------------

  func IsSubsetOf(other: TSet): Bool
    var keys := self.FDict.Keys
    for(var i := 0; i < keys.Len(); i += 1) do
      if(not other.Contains(keys[i])) then
        return false
    return true

  func IsSupersetOf(other: TSet): Bool
    return other.IsSubsetOf(self)

  func Equals(other: TSet): Bool
    if(self.Len() != other.Len()) then return false
    return self.IsSubsetOf(other)

  // -- Iteration Support ------------------------------------

  property Items(): array of T
    return self.FDict.Keys

  property __index__(index: Int32): T
    return self.FDict.Keys[index]