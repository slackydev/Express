type
  Exception = class
    const Message: string

    constructor Create(aMessage: string)
      self.Message := aMessage
  
  ENativeError = class(Exception)
  ERangeError = class(Exception)



// This is a magic compiler variable, and must never be free'd.
var __G_NativeExceptionTemplate := new ENativeError('A native VM error occurred');
var __G_RangeExceptionTemplate  := new ERangeError('Index out of range');