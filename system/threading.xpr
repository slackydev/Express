func __TThreadExecutionMethod(param: Pointer)
  var threadObj:TThread = param
  threadObj.Execute()
 
type
  TExecutionFunc = func(Pointer)
  TThread = class
    var Handle: Int64
    var FTerminated: Bool
    var FSuspended: Bool
    var FCallback: TExecutionFunc

    constructor Create(createSuspended: Bool)
      Self.FTerminated := False
      Self.FSuspended := createSuspended

      Self.FCallback := __TThreadExecutionMethod;
      Self.Handle := 0
      
      if(not createSuspended) then
        Self.Start()
    
    @virtual
    func Execute()
      raise Exception('VIRTUAL METHOD STUB REACHED')

    @virtual
    func Free()
      if (Self.Handle != 0) then
        ThreadClose(Self.Handle)
        Self.Handle := 0

    func Start()
      if (Self.FSuspended and Self.Handle != 0) then
        ThreadResume(Self.Handle)
        Self.FSuspended := False
      else  
        Self.FSuspended := False;
        Self.Handle := ThreadSpawn(Self.FCallback, Self)
        
    func Suspend()
      if (Self.FSuspended and Self.Handle != 0) then
        ThreadSuspend(Self.Handle)
        Self.FSuspended := True
    
    func Terminate()
      ThreadJoin(Self.Handle)
      Self.FTerminated := True
      Self.Handle := 0;
    
    func Terminated(): Bool
      return Self.FTerminated

    func Join()
      if (Self.Handle != 0) then
        ThreadJoin(Self.Handle)
        Self.FTerminated := True
        Self.Handle := 0;