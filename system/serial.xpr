import 'system/threading.xpr' as *
(*
  A few critical issues are found by writing this:

  1) if TSerialWorker needs TSerial, and TSerial needs TSerialWorker 
     we get infinite compiler loop - stack overflow
     workaround "type TSerialBase = class"

  2) [SOLVED missing incref] 
     (self.owner as TSerial).something causes crashes.

  3) [SOLVED special handling needed] 
     lambda can not compare to nil directly. Must access .method field.
*)

type TLineCallback = lambda(string)
type TByteCallback = lambda(UInt8)
type TSerialBase = class

// ============================================================
// Internal worker thread (NOT exposed to users)
// ============================================================
type TSerialWorker = class(TThread)
  var owner: TSerialBase

  constructor Create(o: TSerialBase)
    self.owner := o
    inherited(False)
  
  @override
  func Free()
    inherited()

  @override
  func Execute()
    var b: UInt8
    
    var serial := self.owner as TSerial
    var UseHandle := serial.handle

    while True do
      serial.lock.Lock()
      var canContinue := serial.running and (not self.Terminated())
      serial.lock.Unlock()
      
      if not canContinue then break
      
      var n := SerRead(UseHandle, addr(b), 1)
      
      if (n > 0) then serial.ProcessByte(b)
      if (n = 0) then sleep(1)


// ============================================================
// Public API
// ============================================================

type TSerial = class(TSerialBase)
  var handle: Int32
  var worker: TSerialWorker

  var running: Bool

  var lineBuf: string

  var OnLine: TLineCallback
  var OnByte: TByteCallback
  var lock: TCriticalSection
  
  // -------------------------
  // Constructor
  // -------------------------
  constructor Create(device: string; baud: Int32)
    self.handle := SerOpen(device)

    self.running := False
    self.lineBuf := ''
    self.lock := self.lock.Create()

    if (self.handle >= 0) then
      SerSetParams(self.handle,
                   baud,
                   8,
                   TSerialParity.NoneParity,
                   1,
                   0)



  // -------------------------
  // Start async reader
  // -------------------------
  func Start()
    if (self.handle < 0) then
      print 'Serial not open'
      return

    if (self.worker = nil) then
      self.running := True
      self.worker := new TSerialWorker(self)


  // -------------------------
  // Stop async reader
  // -------------------------
  func Stop()
    self.lock.Lock()
    self.running := False
    self.lock.Unlock()
    
    if (self.worker != nil) then
      self.worker.Join()
      self.worker := nil


  // -------------------------
  // Close port
  // -------------------------
  func Close()
    self.Stop()

    if (self.handle >= 0) then
      SerClose(self.handle)
      
      self.lock.Lock()
      self.running := False
      self.lock.Unlock()
    
      self.lock.Lock()
      self.handle := -1
      self.lock.Unlock()

  // -------------------------
  // Sync read 
  // -------------------------
  func ReadLine(): string
    var s: string = ''
    var b: UInt8

    while (true) do
      var n := SerRead(self.handle, addr(b), 1)

      if (n > 0) then
        if (b = 10) then
          return s
        elif (b != 13) then
          s += chr(b)
      else
        sleep(2)


  // -------------------------
  // Sync read raw bytes
  // -------------------------
  func Read(count: Int32): array of UInt8
    var out: array of UInt8
    out.SetLen(count)

    var n := SerRead(self.handle, addr(out[0]), count)

    if (n <= 0) then
      out.SetLen(0)

    return out


  // -------------------------
  // Write raw
  // -------------------------
  func Write(data: Pointer; count: Int32): Int32
    return SerWrite(self.handle, data, count)


  // -------------------------
  // Write string
  // -------------------------
  func WriteString(s: string)
    if (self.handle >= 0) then
      SerWrite(self.handle, addr(s[0]), s.Len())


  // -------------------------
  // Internal byte processing
  // -------------------------
  func ProcessByte(b: UInt8)
    if (self.OnByte != nil) then
      self.OnByte(b)

    if (b = 10) then
      if (self.OnLine != nil) then
        self.OnLine(self.lineBuf)
      
      self.lock.Lock()
      self.lineBuf := ''
      self.lock.Unlock()

    elif (b != 13) then
      self.lock.Lock()
      self.lineBuf += chr(b)
      self.lock.Unlock()
      
  // -------------------------
  // Flush helpers
  // -------------------------
  func Flush()
    SerSync(self.handle)
    SerFlushOutput(self.handle)

  // -------------------------
  // State
  // -------------------------
  func IsOpen(): Bool
    self.lock.Lock()
    Result := self.handle >= 0
    self.lock.Unlock()

  // -------------------------
  // Destructor-like cleanup
  // -------------------------
  func Free()
    self.lock.Destroy()
    self.Close()