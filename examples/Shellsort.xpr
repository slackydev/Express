(*
  March-31-2026 update [better shellsort - better JIT]

  Lape: 703ms [r:off]
  Expr: 62ms (max) [r:on=85ms],  320ms (low),   420ms (off) [r:on=665ms]
  FPC : 46ms [r:on=120ms]
*)

@opt('jit:low; rangechecks:off')
func main()
  var arr: array of int
  arr := [for var i:=1 to 500 000 do RandInt(0,$FFFFFF)]
  
  var n: Int = arr.Len();
  var before := MarkTime()

  // sort
  var gaps := [3735498,1769455,835387,392925,184011,85764,39744,18298,8359,3785,1695,749,326,138,57,23,9,4,1]

  for(var gap in gaps) do
    if(gap >= n)then continue
    
    for(var i:=gap;i<n;i+=1) do
      var key := arr[i]
      var j   := i - gap
      while(j >= 0 and arr[j] > key) do
        arr[j + gap] := arr[j]
        j -= gap
      
      arr[j + gap] := key

  print 'Used ${MarkTime() - before} ms'
  
  for(var i:=0; i<n; i+=n div 10) do
    print arr[i]


main()
