{$jit max}

func dotproduct()
  var a, b: array of double
  var n: Int = 10 000 000
  var dot: double = 0.0
 
  a.SetLen(n)
  b.SetLen(n)
  
  n := a.len()
  var start := MarkTime()
  for(var i:= 0; i < n; i += 1) do
    a[i] := i % 1000
    b[i] := (i * 7) % 1000
  
  var before_dp := MarkTime()
  for(var i: Int = 0; i < n; i += 1) do
    dot += a[i] * b[i]

  var after := MarkTime()
  
  print 'Dot product used:',(after - before_dp),'ms'
  print 'Full test used:  ',(after - start),'ms'
  print 'Result =',dot.ToStr()


dotproduct()