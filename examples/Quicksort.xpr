(*
 Showcasing the very basic generics that exist to reduce some boilerplate. 
 Currently very limited, but still useful to prevent repetition.
 
 The initial `array` is a constraint for self-type, in the same way as numeric is.
 class, array, numeric, type [anything], are hardcoded constraints.
*)
{$jit off}
{$rangechecks on}

@opt('jit: max; rangechecks: false')
func array.QuickSort<T:numeric>(left, right: Int32);
  if(left >= right) return

  var pivot := self[(left + right) / 2]
  var i := left
  var j := right
  
  while(i <= j) do
    while(self[i] < pivot) i += 1
    while(self[j] > pivot) j -= 1

    if(i <= j) then
      (self[i], self[j]) := [self[j],  self[i]]
      i += 1
      j -= 1
  
  if(left < j)  self.QuickSort(left, j)
  if(i < right) self.QuickSort(i, right)

var n: Int = 10
var arr: array of int16;
arr := [for var _:=1 to n do RandInt(0, n)]

var t := GetTickCount()

arr.Quicksort(0, arr.High())

print (GetTickCount() - t).ToStr() +'ms!'
print arr
