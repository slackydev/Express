type 
  TPoint = (x,y: Int)
  TPointArray = array of TPoint
  T2DPointArray = array of TPointArray

@opt('jit:low; rangechecks: false')
func SplitTPA(Points: TPointArray DistX, DistY: Int): T2DPointArray
  if(Points.High() = -1) then
    return nil
  
  if(Points.High() = 0) then
    Result := [Points]
    return Result
  
  var xsq := DistX * DistX
  var ysq := DistY * DistY
  var xxyy := xsq * ysq
  
  var LastIndex := Points.High()
  var ProcCount := 0
  var Current: TPointArray
  Current.SetLen(LastIndex+1);
  
  while (LastIndex - ProcCount >= 0) do
    Current[0] := Points[0]
    Points[0] := Points[LastIndex - ProcCount]
    ProcCount += 1
    
    var ClustSize := 1
    var i := 0
    
    pass // hint, new JIT body - reduce trace, speed++
    while(i < ClustSize)do
      var j := 0
      const p1 := Current[i];
      
      while(j <= LastIndex - ProcCount) do
        var dx := p1.x - Points[j].x
        var dy := p1.y - Points[j].y

        if ((dx*dx * ysq) + (dy*dy * xsq) <= xxyy) then
          Current[ClustSize] := Points[j]
          Points[j] := Points[LastIndex - ProcCount]
          
          ProcCount += 1
          ClustSize += 1
          j -= 1
        j += 1
      i += 1

    Result.SetLen(Result.Len()+1)
    Result[Result.High()] := Current.Slice(0, ClustSize)


@opt('jit:low; rangechecks: false')
func SplitTPA_Expressive(Points: TPointArray; DistX, DistY: Int): T2DPointArray
  var unvisited := Points.Copy()
  var xsq := DistX * DistX
  var ysq := DistY * DistY
  var xxyy := xsq * ysq
  var neighbors: TPointArray;
  
  while (unvisited.Len() > 0) do
    var cluster: TPointArray
    cluster.Append(unvisited.Pop())
    
    var i := 0
    while (i < cluster.Len()) do
      var core := cluster[i]
      neighbors :=[for var p in unvisited do 
                   where (((core.x - p.x)*(core.x - p.x)*ysq) + 
                          ((core.y - p.y)*(core.y - p.y)*xsq) <= xxyy) p]
      cluster := cluster.Concat(neighbors)
      unvisited :=[for var p in unvisited do 
                   where (((core.x - p.x)*(core.x - p.x)*ysq) + 
                          ((core.y - p.y)*(core.y - p.y)*xsq) > xxyy) p]
      i += 1

    Result.Append(cluster)


@opt('jit:low; rangechecks: false')
func SplitTPA_Recursive(pts: TPointArray; w, h: Int): T2DPointArray
  var lo := 0
  var hi := pts.High()
  var sqx := w*w
  var sqy := h*h
  var sqxy := sqx*sqy

  @opt('jit:low; rangechecks: false')
  func connect(p: TPoint)
    var top := hi
    for (var i := hi; i > lo; i -= 1) do
      var dx := p.x - pts[i].x
      var dy := p.y - pts[i].y
      if (dx*dx*sqy + dy*dy*sqx <= sqxy) then
        (pts[i], pts[hi]) := [pts[hi], pts[i]]
        hi -= 1
    
    for (var i := hi + 1; i <= top; i += 1) do
      connect(pts[i])
  
  while (lo <= hi) do
    var top := hi
    connect(pts[lo])
    Result.Append(pts.Slice(hi + 1, top + 1).Concat([pts[lo]]))
    lo += 1


func GeneratePoints(N: Int): TPointArray
  Result.SetLen(N)
  for(var i:=0; i < n; i+=1) do
    Result[i].X := RandInt(0,1000)
    Result[i].Y := RandInt(0,1000)

  return Result


func Benchmark()
  var P := GeneratePoints(10000)

  var t0 := MarkTime()
  var Clusters := SplitTPA(P.Copy(), 14,14)
  var t1 := MarkTime()

  print 'Clustering used ${t1 - t0} ms'
  print 'Produced ${clusters.len()} clusters'
  
  var t0 := MarkTime()
  var clusters := SplitTPA_Expressive(P.Copy(), 10,10)
  var t1 := MarkTime()

  print 'Clustering functional used ${t1 - t0} ms'
  print 'Produced ${clusters.len()} clusters'
  
  var t0 := MarkTime()
  var Clusters := SplitTPA_Recursive(P.Copy(), 10,10)
  var t1 := MarkTime()

  print 'Clustering recursive used ${t1 - t0} ms'
  print 'Produced ${clusters.len()} clusters'

Benchmark()