@opt('inline:on;jit:max')
func bitcount(n: Int): Int; // inline (w/max jit) = approx 3x faster
  while(n != 0) do
    n := n & (n - 1)
    Result += 1

@jit('max')
func hemmingweight();
  var before := GetTickCount()

  var res: Int = 0
  for(var i:= 1; i <= 5 000 000; i+=1) do
    res += bitcount(i)
  
  print 'Time used (ms): ${GetTickCount() - before}'
  print 'Hamming = $res'

hemmingweight();
