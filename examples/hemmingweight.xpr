{$jit off}
{$inline off}
{$rangechecks off}

@opt('inline;jit')
func bitcount(n: Int): Int; // inline (w/max jit) = approx 3x faster
  while(n != 0) do
    n := n & (n - 1)
    Result += 1


@jit('max')
func hemmingweight();
  var before := MarkTime()

  var res: Int = 0
  for(var i:= 1; i <= 5 000 000; i+=1) do
    res += bitcount(i)
  
  print 'Time used (ms): ${MarkTime() - before}'
  print 'Hamming = $res'

hemmingweight()
