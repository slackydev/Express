(*
  Snippet was taken from villavu forums for a simple test against LaPe.
  Slightly modified to ensure advanced compilers cant rely on CSE.
  originally used as a test Lape against PascalScript
*)

func lapeisfast();
  var a := 1594
  var b := 0
  var hits: Int

  @jit('max')
  for(var i:Int=0; i <= 10 000 000; i+=1) do
    b := i / a;
    b := b + a * (i & 2047)
    b := b - a * (i & 1023)

    if(a = b) then hits += 1

  print i
  print hits


var t := MarkTime()
lapeisfast()
print Round(MarkTime() - t,3),'ms'

