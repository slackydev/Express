
func main()
  var n: Int = 100 000 000 // 100 million iterations
  var sign: double = 1.0
  var before := MarkTime()
  var _pi: double;
  
  @jit('low')
  for(var i: Int = 0; i < n; i += 1) do
    _pi += sign / (2 * i + 1)
    sign := -sign
  
  _pi := _pi * 4.0
  
  var after := MarkTime()
  print after - before
  print _pi


print 'Running pi'
main()
