
{$rangechecks off}
{$jit low}

func main();
  var arr: array of Int64 
  arr.SetLen(500000);
  
  var n: Int64 = arr.High() + 1;

  for(var i: Int64=0; i<n; i+=1)
    arr[i] := RandInt(0, n)
  
  var before := GetTickCount()
  
  // sort
  var gap: Int64 = 0
  while(gap <= (n-1) div 3)
    gap := gap * 3 + 1
  
  while(gap >= 1) do 
    for(var i: Int64 = gap; i < n; i+=1) do
      var j:Int64 = i
      
      while(j >= gap and arr[j] < arr[j-gap]) do
        var tmp := arr[j]
        arr[j] := arr[j-gap]
        j := j - gap
        arr[j] := tmp

    gap := gap / 3;
  
  var after := GetTickCount()
  print after - before
 
  
  for(i:=0; i<n; i+=arr.len()/10)
    print arr[i];

main();

  
    
    
    
    
