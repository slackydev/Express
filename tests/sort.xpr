{$rangechecks off}
{$jit max}

func array of int.insertionSort(left, right: Int)
  for (var i := left + 1; i <= right; i += 1) do
    var key := self[i]
    var j := i - 1
    while((j >= left) and (self[j] > key))do
      self[j+1] := self[j]
      j -= 1
    self[j+1] := key


func MergeSort(arr: array of int); 
  const RUN := 24
  var buf: array of int
  
  func Merge(L, M, R: Int)
    var I := L;
    var J := M + 1;
    var K := L;
    while (I <= M) and (J <= R) do
      if arr[I] <= arr[J] then
        buf[K] := arr[I]
        i+=1
      else
        buf[K] := arr[J]
        j+=1
      k+=1
    
    if I <= M then Move(arr[I], buf[K], (M - I + 1) * SizeOf(arr[0]))
    if J <= R then Move(arr[J], buf[K], (R - J + 1) * SizeOf(arr[0]))
    Move(buf[L], arr[L], (R - L + 1) * SizeOf(arr[0]))

  var N := arr.len();
  if N <= 1 then return;

  var L := 0;
  while L < N do
    arr.InsertionSort(L, Min(L + RUN - 1, N - 1))
    L += RUN
  
  buf.SetLen(N)
  var width := RUN
  while width < N do
    L := 0
    while L < N do
      var M := L + width - 1
      if M >= N - 1 then Break

      var R := L + 2 * width - 1
      if R >= N then R := N - 1

      if arr[M] > arr[M + 1] then
        Merge(L, M, R)

      L += 2 * width

    width *= 2;


func main();
  var arr: array of Int64 
  arr.SetLen(300000);
  
  var n: Int64 = arr.High() + 1;

  for(var i: Int64=0; i<n; i+=1) do
    arr[i] := RandInt(0, n)
  
  var before := MarkTime()
  MergeSort(arr)
  print MarkTime() - before,'ms'
 
  for(i:=0; i<n; i+=arr.len()/10) do
    print arr[i];

main();



  
    
    
    
    
