{$jit max}

@inline
func bitcount(n: Int64): Int64;
  while(n != 0) do
    n := n & (n - 1)
    Result := Result + 1


func main();
  var before := MarkTime()
  
  var result: Int64 = 0
  for(var i:= 1; i <= 5 000 000; i:=i+1) do
    result := result + bitcount(i)

  var after := MarkTime()
  print after - before
  print result


main();