import 'system/system.xpr'
  
// Enum windows
@native('user32.dll::EnumWindows')
func EnumWindows(lpEnumFunc: Pointer; lParam: Int64): Int32; stdcall;

@native('user32.dll::GetWindowTextA')
func GetWindowText(hwnd: Int64; lpString: system::PChar; nMaxCount: Int32): Int32; stdcall;

var count := 0
var t := MarkTime()
var cb := create_callback(lambda(hwnd: Int64; lParam: Int64): Int32 (
  var str: string
  str.setlen(256)
  var length := GetWindowText(hwnd, system::PChar(str), 255)
  if(length > 0)then
    str.setlen(length)
    print 'Window Handle: $hwnd - Title: ${str}'
    count += 1

  return 1
  ), system::ffi_cdecl
)
print MarkTime() - t,'ms'

var t := markTime();
EnumWindows(cb, 0)
print markTime() - t
free_callback(cb) // manually managed instance for now

print 'EnumWindows found $count windows'