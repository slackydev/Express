(*
  Snippet was taken from villavu forums for a simple test against LaPe,
  originally used as a test Lape against PascalScript
*)
@jit('max')
func main();
  var a: Int64 = 1594;
  var b: Int64 = 0;
  var hits: Int64 = 0;

  for(var i:Int64=0; i <= 10 000 000; i+=1) do
    b := i / a
    b := b + a * (i & 2047)
    b := b - a * (i & 1023)

    if(a = b) hits += 1;

  print i
  print hits

var t := gettickcount()
main();
print 'used:',gettickcount() - t,'ms'

