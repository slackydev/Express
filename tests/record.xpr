
type 
  TStopWatch = record
    last_time: Double 
    running: Bool     
    total: Double     

func TStopWatch.Reset()
  self.running := false
  self.last_time := 0.0
  self.total := 0.0
  print 'reset'


func TStopWatch.Start()
  if(not Self.Running) then
    self.running := true
    self.total := 0.0
    self.last_time := GetTickCount()
    print 'started'


func TStopWatch.Stop()
  if (self.running) then
    self.total := self.total + GetTickCount() - self.last_time
    self.running := false
    print 'stopped'

func TStopWatch.Read(): Float
  if (self.running) then
    var t := GetTickCount()
    self.total := self.total + t - self.last_time
    self.last_time := t

  return self.total


// -------------

func recref(ref test: TStopWatch)
  test.Reset()
  test.Start()
  test.Stop()

func rec(test: TStopWatch)
  test.Reset()
  test.Start()
  test.Stop()
  
  recref(test)

var test: TStopWatch;
rec(test)

print sizeof(test) // 24
print PtrInt(addr(test.last_time) - addr(test)) // 0
print PtrInt(addr(test.running) - addr(test))   // 8
print PtrInt(addr(test.total) - addr(test))     // 15







