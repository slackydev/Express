
type TLambda = lambda(int): int

const myGlobal: int = 100;

func LambdaTest1(f: TLambda): Int64
  print 'LAMBDA'
  print f(10)


func LambdaTest2(f: TLambda): Int64
  LambdaTest1(f)


func LambdaMain()
  func local_sqr(x: Int): Int
    return x*x
  
  var sqr := local_sqr;
  var myLocal := 10
  LambdaTest2(lambda(x:int):int => sqr(myLocal) * x + myGlobal);


LambdaMain()


// ------------------------
type TFunc = func(int): int;

func Test1(f: TFunc): Int64;
  print 'FUNC'
  print f(myGlobal)

func Test2(f: TFunc): Int64;
  Test1(f)

func sqr(x: int): int
  Result := x*x;

func main();
  Test2(sqr);


main();