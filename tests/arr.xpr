{$inline off}

func SetItemRef(ref a: Int)
  a := 1000;
  
var arr: array of Int;
arr.setlen(5)
SetItemRef(arr[0])

print arr

var t: Int;
SetItemRef(t);
print t


// KEEP shows where we can tweak refcounting
// a lot of temps, some tostring stuff, much cleanup all in a loop.
// Possibly slower than needs to be.
// Refcount and Collect strategy is one of those cases we can put in more work.
var arr: array of Int64;

arr.SetLen(1000000);

var t := MarkTime();
var H := arr.High()
for var i:=0;i<=H; i+= 1 do
  IntToStr(arr[i]) + IntToStr(arr[i]) + \
  IntToStr(arr[i]) + IntToStr(arr[i]) + \
  IntToStr(arr[i]) + IntToStr(arr[i]) + \
  IntToStr(arr[i]) + IntToStr(arr[i]) + \
  IntToStr(arr[i]) + IntToStr(arr[i])

print MarkTime() - t,'ms'
 