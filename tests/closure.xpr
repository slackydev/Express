func example(f: lambda(int): int)
  print f(100)
  
func sqr(x: int): int
  return x*x

func closure()
  
  var local1: int32 = 10;
  
  var test := lambda(x: int): int 
    Result := x*local1
    local1 += 1
  
  print test(10)
  print local1, local1 = 11
  
  example(test)
  print local1, local1 = 12
  
  // none capturing regular function
  example(sqr) 


closure()
