{$rangechecks on}

type 
  TFoo = class
    var flops: array of float
    
    constructor Create()
      self.flops.setlen(6)
    
    func Run()
      self.flops[0] := 55
      self.flops[1] := 65
      self.flops[2] := self.flops[1] // Good faulty array refcount trigger - keep it.

    func Free()
      print '>> REALEASED: TFoo'

func test_rc_class();
  var foo: TFoo = new TFoo()
  foo.Run()

test_rc_class()