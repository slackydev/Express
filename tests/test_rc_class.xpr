{$rangechecks on}
type 
  TBar = class
    var str: string;
    
  TFoo = class(TBar)
    var flops: array of float
    
    constructor Create()
      self.flops.setlen(6)
    
    func Run()
      self.flops[0] := 55
      self.flops[1] := 65
      self.flops[2] := self.flops[1] // Good faulty array refcount trigger - keep it.

    func Free()
      print '>> REALEASED: TFoo'

func test_rc_class();
  var foo: TFoo = new TFoo()
  var t: TBar;
  for var i:=0; i < 1000; i += 1 do
    t := (foo as TBar)
    
  for var i:=0; i < 1000; i += 1 do
    (foo as TBar)
  
  foo.Run()

test_rc_class()

// ---- Test leak in try-except
var r:Exception = new ERangeError('loop throw')
for var i:=0;i<100;i+=1 do
  try
    raise r
  except on E: Exception do
    pass
    
for var i:=0;i<10;i+=1 do
  try
    raise ERangeError('loop throw')
  except on E: Exception do
    pass

for var i:=0;i<100;i+=1 do
  try
    1/0
  except on E: Exception do
    pass