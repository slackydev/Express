type 
  TAnimal = class 
    const ID: Int32 = 0;
    var name: string
    var agility: Int32 = 85;
    var strength: Int32 = 50;
    
    constructor Create(aName: string)
      self.name := aName
      self.ID := 1;
    
    @virtual
    func Speak()
      print 'Undefined'
    
    @virtual
    func Foo()
      print 'i am parent'
    
    @virtual
    func Foo(x,y: Int32): Int32
      return x*y;
    
    @virtual
    func Free()
      print 'freeing base'


  TCat = class(TAnimal)
    @override
    func Speak()
      print self.name + ' says meow'
    
    @override
    func Foo()
      inherited()
      print self.strength / 2

    @override
    func Free() // called automatically
      print 'child freeing'
      inherited()


  TSavannah = class(TCat)
    @override
    func Speak()
      print self.name + ' says RAWR!!'

  
var myBigCat: TAnimal = new TSavannah('Savannah')
myBigCat.Speak()
print '----------------'
// Nope.. typemethods are weaker than class methods
func TCat.Speak()
  print self.name + ' says KAPOW!'

var myCat: TAnimal = new TCat('Missy')
myCat.Speak()
myCat.Foo()
myCat.Foo(10,10)
myCat.Speak()
print '----------------'
print 'Name is ${myCat.name}'
print 'ID is ${myCat.ID}'
print 'Agility is ${myCat.Agility}'
print 'Strength is ${myCat.Strength}'
print '----------------'