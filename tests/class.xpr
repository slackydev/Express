(*
  We could make classes more complex, and have programmers be explicit
  using annotations for virtual methods.
  ```
  @virtual
  func VMTMethod()
    print 'Lives in virtual method table'
  ```
  And in all other cases make it type methods. Should be a very small addition
  But once we go down this path, override also becomes essential.
*)
type 
  TAnimal = class 
    const ID: Int32 = 0;
    var name: string
    var agility: Int32 = 85;
    var strength: Int32 = 50;
    
    constructor Create(aName: string)
      self.name := aName
      self.ID := 1;
    
    @virtual
    func Speak()
      print 'Undefined'
    
    @virtual
    func Foo()
      print 'i am parent'
    
    @virtual
    func Foo(x,y: Int32): Int32
      return x*y;
    
    func Free()
      print 'freeing'


  TCat = class(TAnimal)
    @override
    func Speak()
      print self.name + ' says meow'
    
    @override
    func Foo()
      inherited()
      print self.strength / 2

    func Free() // called automatically
      print 'child freeing'


// Technically - we can make this a VMT override cuz it exists.
// but late OVERLOADS and NEW METHODS will **NOT** be added to the VMT.
// So this should never execute, VMT takes priority!
func TCat.Speak()
  print 'NO!'

var myCat: TAnimal = new TCat('Missy')
myCat.Speak()
myCat.Foo()
myCat.Foo(10,10)
print '----------------'
print 'Name is ${myCat.name}'
print 'ID is ${myCat.ID}'
print 'Agility is ${myCat.Agility}'
print 'Strength is ${myCat.Strength}'
print '----------------'