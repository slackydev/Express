//import 'tests/math.xpr';


func foo();
  var maxDepth: Int = 6
  
  func recurse(depth: Int): Int8; 
    print 'outer recurse ${depth}, ${maxDepth}'
    if(depth = maxDepth)then
      return maxDepth
    else
      return recurse(depth+1)


  
  func bar();
    var maxDepth: Int8 = 10;
    
    func recurse(depth: Int): Int8;
      print 'nested recurse ${depth}, ${maxDepth}'
      if(depth = maxDepth)then
        return maxDepth
      else
        return recurse(depth+1)

    var res := recurse(0);

    print 'Nested recurse count: '+ res.ToStr();
  
  
  print 'Outer recurse count: ', recurse(0);
  print '------'
  bar();

foo();