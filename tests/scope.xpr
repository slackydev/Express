func foo();
  var maxDepth: Int = 6
  
  func recurse(depth: Int): Int8; 
    print 'outer recurse ${depth}, ${maxDepth}'
    print addr(maxdepth)
    if(depth = maxDepth)then
      return maxDepth
    else
      return recurse(depth+1)


  
  func bar();
    var maxDepth: Int8 = 10;

    func recurse(depth: Int): Int8;
      print 'nested recurse ${depth}, ${maxDepth}'
      if(depth = maxDepth)then
        return maxDepth
      else
        return recurse(depth+1)

    var res := recurse(0);

    print 'recurse gave: '+ res.ToStr();
  
  print recurse(0);

  
  bar();

foo();