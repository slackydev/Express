func helloWorld(id: int)
  print 'hello from thread:', id

var cs: TCriticalSection
cs := cs.Init()
var counter := 0

var threads: array of int

for(var i:=1; i<=10; i+=1) do
  threads.push(
    thread_spawn(lambda(id: int)
          cs.Lock()
          counter += 1
          helloWorld(counter)
          print 'Thread ' + id.ToStr() + ' done'
          cs.Unlock()
    , i)
  )

while(threads.len() > 0) do
  thread_join(threads.pop())

print threads
cs.Destroy()
print 'The counter is: ${counter} 😁'


