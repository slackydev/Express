{.$inline off}
type
  NullableInt = (Value: Int; isNull:Bool)

@inline
operator * (Left: NullableInt; Right:Int): Int;
  Result := Left.value * Right

@autocast; @inline
operator := (ref Left: NullableInt; Right:Int);
  Left.Value := Right;
  Left.IsNull := False;

@autocast; @inline
operator := (ref Left: Int; Right:NullableInt);
  Left := if(Right.IsNull) 0 else Right.Value;

func IntMethod(x: Int)
  print 'Int method from nullable: ', x

func main()
  print '-----------------'
  var t: NullableInt;
  var sum: Int = 0;
  t := 999;
  
  print 'Cast to int', Int(t)
  
  if Int(t) > 100 then
    print 'if-else cast:', t
  
  IntMethod(t)
  sum := t;
  print sum
  print '-----------------'

main();


type
  TRec3 = (x,y,z: Int32);
  TRec2 = (x,y: Int32);
  TRec1 = (x: Int32);

var a: TRec1;
var b: TRec2;
var c: TRec3;

operator := (ref LHS:TRec1; RHS: TRec2);
  LHS.x := RHS.x;

operator := (ref LHS:TRec1; RHS: TRec3);
  LHS.x := RHS.x;

b.x := 99;
c.x := 50;

a := b;
print 'a := b ->',a.x;
a := c;
print 'a := c ->',a.x;

print '-----------------'

// Maybe allow casts through overloads?
// In the end .. casts are assignments.
@autocast; 
operator := (ref LHS:Int; RHS: TRec2);
  print 'Cast TRec2 to Int auto'
  LHS := RHS.x;

func Foo(x: Int): Int;
  return x

var test: TRec2 = [10,2]

print 'Autocast calltest gave: ', Foo(test);

@autocast; 
operator := (ref LHS:TRec1; RHS: TRec2) 
  LHS.x := RHS.x;

a := [1,2];
print 'Initializer list TRec2 to TRec1:', a

@autocast; 
operator := (ref LHS:Int32; RHS: TRec2); 
  LHS := RHS.x;

var a: Int32 = [1,2];
print 'Initializer list assign to int:',a
  
print '-----------------'



