func main()
  var a, b: array of double
  var n: Int = 10 000 000
  
  a.SetLen(n)
  b.SetLen(n)
  
  n := a.len()
  // trace starts AFTER the call to GetTickCount
  // upon assigning result to start!
  var start := GetTickCount() // VIP 1

  for(var i: Int = 0; i < n; i += 1) do  // corrupting VIPs!
    a[i] := i % 1000
    b[i] := (i * 7) % 1000
  end
  
  
  var before_dp := GetTickCount() 
  
  var dot: double = 0
  for(var i: Int = 0; i < n; i += 1) do
    dot += a[i] * b[i]
  end

  var after := GetTickCount()
  
  print 'Dot product used: '+(after - before_dp).ToStr()+' ms'
  print 'Full test used:   '+(after - start).ToStr()+' ms'
  print 'Result = '+dot.ToStr()
end;

main();