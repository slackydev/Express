
type EImpossible = class(Exception) end;


try
  var test: float = 100.0 * 2.0;
  print test / 0.0
except on E: ENativeError do
  print '>>> Native: '+E.Message
except on E: EImpossible do
  print 'Its impossible'
end;

print 'We are still good!'


type TFoo = class var x: Int32; end;
type TBar = class var x: Int32; end;

var foo := new TFoo();
try
  foo as TBar;
except on E: Exception do
  print 'Its impossible to do!';
  print '>>> '+ E.Message;
end;

{$jit max}
{$rangechecks on}

var arr: array of int
arr.Setlen(1000000)
var t:=GetTickCount()

for(var i:=0; i<1000000; i+=1)
  arr[i]

print GetTickCount() - t