type EImpossible = class(Exception)


try
  var test: int = 100 * 2
  print test / 0
except on E: ENativeError do
  print '>>> Native: '+E.Message
except on E: EImpossible do
  print 'Its impossible'


print 'We are still good!'


type TFoo = class var x: Int32
type TBar = class var x: Int32

var foo := new TFoo()
try
  foo as TBar;
except on E: Exception do
  print 'Its impossible to do!';
  print '>>> '+ E.Message;

{$jit on}
{$rangechecks off}

var arr: array of int
arr.Setlen(10000000)
var t:=GetTickCount()

for(var i:=0; i<10000000; i+=1) do
  arr[i]

print GetTickCount() - t


try
  print 1 / 0
except on E: ENativeError do
  print 'Reraise test:'
  raise E