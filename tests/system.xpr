// weakness, this can reach methods defined before import, in the unit importing it
// this may cause unreliable behavior due to overload resolution.
var SYS_CONST := 999999;

func SysFunc();
  print 'sys'

type 
  TUnitTest = class 
    var name: string
    
    func Create(aName: string)
      self.name := aName
    
    func HelloWorld()
      print self.name

func Int.Inc(step: Int): Int
  print 'system Inc'
  self += step
  return self

func Int.Dec(step: Int): Int
  self -= step
  return self