func main()
  var n: Int = 100 000 000 // 100 million iterations
  var _pi: double = 0.0
  var sign: double = 1.0
  var before := MarkTime()
  
  for(var i: Int = 0; i < n; i += 1) do
    _pi += sign * 1.0 / (2 * i + 1)
    sign := -sign
  
  _pi := _pi * 4.0
  
  var after := MarkTime()
  print after - before
  print _pi

main()