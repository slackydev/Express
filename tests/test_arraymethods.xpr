type TIntArray    = array of Int
type TFloatArray  = array of Double
type TStrArray    = array of String

// ============================================================
// Append / Pop
// ============================================================
print 'Append / Pop'

var a: TIntArray
a.Append(10)
a.Append(20)
a.Append(30)

Validate(a.Len().ToStr(),  '3',  'Append: len after 3 Appendes')
Validate(a[0].ToStr(),     '10', 'Append: first element')
Validate(a[2].ToStr(),     '30', 'Append: last element')

var popped := a.Pop()
Validate(popped.ToStr(),   '30', 'Pop: returned value')
Validate(a.Len().ToStr(),  '2',  'Pop: len after pop')
Validate(a[1].ToStr(),     '20', 'Pop: remaining last element')

// ============================================================
// Slice
// ============================================================
print 'Slice'

var b: TIntArray
b.Append(1)
b.Append(2)
b.Append(3)
b.Append(4)
b.Append(5)

var s1 := b.Slice(2)
Validate(s1.ToStr(), '[3, 4, 5]', 'Slice(from): tail')

var s2 := b.Slice(1, 4)
Validate(s2.ToStr(), '[2, 3, 4]', 'Slice(from, to): middle')

var s3 := b.Slice(0, 2)
Validate(s3.ToStr(), '[1, 2]', 'Slice(0, 2): head')

// ============================================================
// Copy
// ============================================================
print 'Copy'

var c := b.Copy()
Validate(c.ToStr(), b.ToStr(), 'Copy: same contents')

c[0] := 99
Validate(b[0].ToStr(), '1', 'Copy: independent from original')

// ============================================================
// Contains / IndexOf
// ============================================================
print 'Contains / IndexOf'

Validate(b.Contains(3),       'Contains: existing element')
Validate(not b.Contains(99),  'Contains: missing element')

Validate(b.IndexOf(3).ToStr(), '2',  'IndexOf: existing element')
Validate(b.IndexOf(99).ToStr(), '-1', 'IndexOf: missing element')

// ============================================================
// Delete
// ============================================================
print 'Delete'

var d: TIntArray
d.Append(10)
d.Append(20)
d.Append(30)
d.Append(40)

d.Delete(1)
Validate(d.ToStr(), '[10, 30, 40]', 'Delete: middle element')
Validate(d.Len().ToStr(), '3', 'Delete: len after delete')

d.Delete(0)
Validate(d.ToStr(), '[30, 40]', 'Delete: first element')

d.Delete(d.High())
Validate(d.ToStr(), '[30]', 'Delete: last element')

// ============================================================
// Insert
// ============================================================
print 'Insert'

var ins: TIntArray
ins.Append(1)
ins.Append(3)
ins.Append(5)

ins.Insert(1, 2)
Validate(ins.ToStr(), '[1, 2, 3, 5]', 'Insert: middle')

ins.Insert(0, 0)
Validate(ins.ToStr(), '[0, 1, 2, 3, 5]', 'Insert: front')

ins.Insert(ins.Len(), 6)
Validate(ins.ToStr(), '[0, 1, 2, 3, 5, 6]', 'Insert: end')

// ============================================================
// Remove
// ============================================================
print 'Remove'

var r: TIntArray
r.Append(10)
r.Append(20)
r.Append(30)
r.Append(20)

r.Remove(20)
Validate(r.ToStr(), '[10, 30, 20]', 'Remove: removes first occurrence')

r.Remove(99)
Validate(r.ToStr(), '[10, 30, 20]', 'Remove: no-op for missing value')

// ============================================================
// Reverse
// ============================================================
print 'Reverse'

var rev: TIntArray
rev.Append(1)
rev.Append(2)
rev.Append(3)
rev.Append(4)
rev.Append(5)

rev.Reverse()
Validate(rev.ToStr(), '[5, 4, 3, 2, 1]', 'Reverse: odd length')

var rev2: TIntArray
rev2.Append(1)
rev2.Append(2)
rev2.Append(3)
rev2.Append(4)

rev2.Reverse()
Validate(rev2.ToStr(), '[4, 3, 2, 1]', 'Reverse: even length')

// ============================================================
// Sort
// ============================================================
print 'Sort'

var unsorted: TIntArray
unsorted.Append(5)
unsorted.Append(2)
unsorted.Append(8)
unsorted.Append(1)
unsorted.Append(9)
unsorted.Append(3)

unsorted.Sort()
Validate(unsorted.ToStr(), '[1, 2, 3, 5, 8, 9]', 'Sort: basic sort')

var already: TIntArray
already.Append(1)
already.Append(2)
already.Append(3)
already.Sort()
Validate(already.ToStr(), '[1, 2, 3]', 'Sort: already sorted')

var reverse_sorted: TIntArray
reverse_sorted.Append(5)
reverse_sorted.Append(4)
reverse_sorted.Append(3)
reverse_sorted.Append(2)
reverse_sorted.Append(1)
reverse_sorted.Sort()
Validate(reverse_sorted.ToStr(), '[1, 2, 3, 4, 5]', 'Sort: reverse input')

var dups: TIntArray
dups.Append(3)
dups.Append(1)
dups.Append(2)
dups.Append(1)
dups.Append(3)
dups.Sort()
Validate(dups.ToStr(), '[1, 1, 2, 3, 3]', 'Sort: duplicates')

// ============================================================
// Concat
// ============================================================
print 'Concat'

var ca: TIntArray
ca.Append(1)
ca.Append(2)
ca.Append(3)

var cb: TIntArray
cb.Append(4)
cb.Append(5)

var cc := ca.Concat(cb)
Validate(cc.ToStr(), '[1, 2, 3, 4, 5]', 'Concat: basic')
Validate(ca.ToStr(), '[1, 2, 3]',        'Concat: self unchanged')
Validate(cb.ToStr(), '[4, 5]',           'Concat: other unchanged')

// ============================================================
// Numeric: Sum / Min / Max
// ============================================================
print 'Sum / Min / Max'

var nums: TIntArray
nums.Append(3)
nums.Append(1)
nums.Append(4)
nums.Append(1)
nums.Append(5)
nums.Append(9)
nums.Append(2)
nums.Append(6)

Validate(nums.Sum().ToStr(), '31', 'Sum')
Validate(nums.Min().ToStr(), '1',  'Min')
Validate(nums.Max().ToStr(), '9',  'Max')

// ============================================================
// Numeric: Mean / Variance / StdDev / Median
// ============================================================
print 'Mean / Variance / StdDev / Median'

var stats: TFloatArray
stats.Append(2.0)
stats.Append(4.0)
stats.Append(4.0)
stats.Append(4.0)
stats.Append(5.0)
stats.Append(5.0)
stats.Append(7.0)
stats.Append(9.0)

// Mean = 40/8 = 5.0
Validate('%.1f'.Format(stats.Mean()), '5.0', 'Mean')

// Variance = 4.0 (population)
Validate('%.1f'.Format(stats.Variance()), '4.0', 'Variance')

// StdDev = 2.0
Validate('%.1f'.Format(stats.StdDev()), '2.0', 'StdDev')

// Median of [2,4,4,4,5,5,7,9] = (4+5)/2 = 4.5
Validate('%.1f'.Format(stats.Median()), '4.5', 'Median: even length')

var odd_stats: TFloatArray
odd_stats.Append(1.0)
odd_stats.Append(3.0)
odd_stats.Append(5.0)

Validate('%.1f'.Format(odd_stats.Median()), '3.0', 'Median: odd length')

// ============================================================
// String arrays
// ============================================================
print 'String arrays'

var words: TStrArray
words.Append('hello')
words.Append('world')
words.Append('foo')

Validate(words.Len().ToStr(), '3',                'String array: Append/Len')
Validate(words.Contains('world'),                 'String array: Contains')
Validate(not words.Contains('bar'),               'String array: Contains missing')
Validate(words.IndexOf('foo').ToStr(), '2',       'String array: IndexOf')

words.Remove('world')
Validate(words.ToStr(), "['hello', 'foo']",   'String array: Remove')

words.Reverse()
Validate(words.ToStr(), "['foo', 'hello']",   'String array: Reverse')

// ============================================================
// Edge cases
// ============================================================
print 'Edge cases'

var empty: TIntArray
Validate(empty.Len().ToStr(),  '0',  'Empty: Len')
Validate(empty.High().ToStr(), '-1', 'Empty: High')
Validate(not empty.Contains(1),        'Empty: Contains')
Validate(empty.IndexOf(1).ToStr(), '-1', 'Empty: IndexOf')

var one: TIntArray
one.Append(42)
one.Sort()
Validate(one.ToStr(), '[42]', 'Single element: Sort')
one.Reverse()
Validate(one.ToStr(), '[42]', 'Single element: Reverse')


// ============================================================
// Equallity
// ============================================================
print 'EQ/NEQ'
var s1,s2: string;

s1 := 'hello world'
print (s1 = s2) = False
s2 := 'hello'
print (s1 = s2) = False
s2 += ' world'
print s1 = s2

var a,b: array of int;
a := [1,2,3,4,5,6];
b := [1,2,3,4,5]
print (a = b) = False
b.Append(6)
print (a = b)


print '-----------'
