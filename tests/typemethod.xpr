
func bycopy(x: Int64);
  x := 9999;
  print x

func Int64.bar();
  self := 999;
  bycopy(self);

func Int64.foo();
  print self
  self.bar()

var x: Int64 = 5
x.foo()
print x


func TIntArray.Len(): Int64;
  var result := Length(self);
  return result;

func TIntArray.SetLen(n: Int64);
  SetLength(Self, n);


var arr: TIntArray;
var arg: Int64 = 100;


arr.SetLen(arg);
print arr.Len();



