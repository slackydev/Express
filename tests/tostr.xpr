type TClass = class
  var x,y,z: int
  func create(x,y,z:int)
    (self.x,self.y,self.z) := [x,y,z]

var inst := new TClass(1,2,3);
print inst

type TPerson = class
  var name: String
  var age: Int

var p := new TPerson()
p.name := 'frank'
p.age  := 40

print p