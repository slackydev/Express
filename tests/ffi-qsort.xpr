{$jit max}

type PInt32  = ^Int32
type PUInt32 = ^UInt32
type PUInt8  = ^UInt8
type PInt8   = ^Int8

@native('msvcrt.dll::qsort')
func qsort(base: Pointer; nmemb: Int32; size: Int32; compar: Pointer)

func TestQsort()
  var ptrCmp := lambda(ref x,y: Int): Int
    Result := x - y

  var cmp := create_callback(ptrCmp)
  
  var buf: array of int = [for var _i:=1 to 500000 do RandInt(0,$FFFFFF)]

  var t1 := MarkTime()
  qsort(addr(buf[0]), buf.len(), SizeOf(Int), cmp)
  var t2 := MarkTime()
  
  print buf[0..10]
  print 'qsort used: ${t2-t1}ms'
  free_callback(cmp)


TestQsort()

