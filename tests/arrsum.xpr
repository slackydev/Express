@rangechecks('off')
@jit('off')
func main();
  var arr: array of (x,y: int)
  var n: int = 10 000 000
  var sum: int = 0
  var before, after: double

  arr.SetLen(n)
  
  for(var i:=0; i<n; i += 1) do
    arr[i].x := i % 1000;
    arr[i].y := (i * 7) % 1100;

  before := Marktime()
  for(var i:=0; i<n; i+= 1) do
    sum -= arr[i].x
    sum += arr[i].y
  after := Marktime()

  print 'used: ${after - before} ms'
  print i
  print sum

main();